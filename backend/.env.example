# Google API Key for Gemini models (if LLM_PROVIDER=google)
GOOGLE_API_KEY=your_google_api_key_here

# Groq API Key (if LLM_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API Key (if LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# GitHub Token (if LLM_PROVIDER=github)
GITHUB_TOKEN=your_github_token_here

# LLM Provider: 'google', 'groq', 'openrouter', 'github' (default: google)
LLM_PROVIDER=google
